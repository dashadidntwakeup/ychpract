<Page x:Class="YchPr.Pages.SalesHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:YchPr.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SalesHistoryPage">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информация о партнёре -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Партнёр: " FontWeight="Bold"/>
            <TextBlock x:Name="PartnerNameText" Text="{Binding PartnerName}"/>
            <TextBlock Text=" | Общая сумма продаж: " Margin="20,0,0,0" FontWeight="Bold"/>
            <TextBlock x:Name="TotalSalesText" Text="{Binding TotalSales, StringFormat=N2}"/>
        </StackPanel>

        <!-- Список продаж -->
        <ListView x:Name="SalesListView" Grid.Row="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="120"/>
                    <GridViewColumn Header="Сумма" DisplayMemberBinding="{Binding Amount, StringFormat=N2}" Width="100"/>
                    <GridViewColumn Header="Товар" DisplayMemberBinding="{Binding ProductName}" Width="200"/>
                    <GridViewColumn Header="Количество" DisplayMemberBinding="{Binding Quantity}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Кнопка возврата -->
        <Button Grid.Row="2" Content="Назад" Click="Back_Click" Width="100" Margin="0,10,0,0" HorizontalAlignment="Center"/>
    </Grid>
</Page>
