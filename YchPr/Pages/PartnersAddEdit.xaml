<Page x:Class="YchPr.Pages.PartnersAddEdit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:YchPr.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="PartnersAddEdit">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Наименование</TextBlock>
                <TextBox Text="{Binding NamePartner}"></TextBox>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Тип</TextBlock>
                <ComboBox x:Name="TypeCB" SelectedItem="{Binding TypeOfBusiness}"></ComboBox>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Адрес</TextBlock>
                <TextBox Text="{Binding UrAdress}"></TextBox>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Инн</TextBlock>
                <TextBox Text="{Binding INN}"></TextBox>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Фамилия директора</TextBlock>
                <TextBox Text="{Binding SurnameDirector}"></TextBox>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Имя директора</TextBlock>
                <TextBox Text="{Binding NameDirector}"></TextBox>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Отчество директора</TextBlock>
                <TextBox Text="{Binding PatronumicDirector}"></TextBox>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Телефон</TextBlock>
                <TextBox Text="{Binding Phone}"></TextBox>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Email</TextBlock>
                <TextBox Text="{Binding Email}"></TextBox>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Рейтинг</TextBlock>
                <TextBox Text="{Binding Raiting}"></TextBox>
            </StackPanel>
            <StackPanel  Orientation="Horizontal">
                <Button x:Name="SaveBtn" Click="SaveBtn_Click">Сохранить</Button>
                <Button x:Name="CancelBtn">Отмена</Button>
            </StackPanel>
        </StackPanel>
        
    </Grid>
</Page>
