<Page x:Class="YchPr.Pages.PartnersListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:YchPr.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PartnersListPage" >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
            <TextBox x:Name="SearchBox" Width="300" Margin="5" 
                 TextChanged="SearchBox_TextChanged" 
                 ToolTip="Введите название или фамилию директора"/>
            <TextBlock Text="Сортировать:" VerticalAlignment="Center" Margin="5,0"/>
            <ComboBox x:Name="SortCombo" Width="150" Margin="5"
                  SelectionChanged="SortCombo_SelectionChanged">
                <ComboBoxItem Content="По названию (А-Я)" Tag="NameAsc"/>
                <ComboBoxItem Content="По названию (Я-А)" Tag="NameDesc"/>
                <ComboBoxItem Content="По рейтингу (возрастание)" Tag="RatingAsc"/>
                <ComboBoxItem Content="По рейтингу (убывание)" Tag="RatingDesc"/>
                <ComboBoxItem Content="По скидке (возрастание)" Tag="DiscountAsc"/>
                <ComboBoxItem Content="По скидке (убывание)" Tag="DiscountDesc"/>
            </ComboBox>
        </StackPanel>
        <ListView x:Name="PartnerLW"  Grid.Row="1" >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black"
                        BorderThickness="1" Margin="10">
                        <Grid Margin="10" Width="700">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding TypeOfBusiness.NameBusiness}"/>
                                <TextBlock Text=" | "/>
                                <TextBlock Text="{Binding NamePartners}"/>

                            </StackPanel>

                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding NamePartners}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding SurnameDirector}"/>
                                <TextBlock Text="{Binding NameDirector}"/>
                                <TextBlock Text="{Binding PatronymicDirector}"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" Text="{Binding Phone}"/>
                            <TextBlock Grid.Row="3" Text="{Binding Raiting}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SizeDiscount}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Margin="10">
            <Button x:Name="AddBtn" Click="AddBtn_Click" Margin="5" Padding="10,5"   >Добавить</Button>
            <Button x:Name="EditBtn" Click="EditBtn_Click" Margin="5" Padding="10,5" >Изменить</Button>
            <Button x:Name="DeleteBtn" Click="DeleteBtn_Click" Margin="5" Padding="10,5">Удалить</Button>
            <Button x:Name="HistoryBtn" Click="HistoryBtnClick" Margin="5" Padding="10,5">История продаж</Button> 
            
        </StackPanel>
    </Grid>
</Page>
